# Copy this to .env and adjust for your machine.
#
# This file configures the DEFAULT single-instance cluster. For multiple users
# on a shared VM, do NOT edit this — run `make new-user USER=<name>` instead,
# which generates instances/<name>.env with conflict-free names/ports/subnet.
SPARK_VERSION=3.5.3

# Worker resources — lower these on machines with <8GB RAM
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2

# Master
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=8080

# Worker UIs
SPARK_WORKER1_WEBUI_PORT=8081
SPARK_WORKER2_WEBUI_PORT=8082

# Jupyter
JUPYTER_PORT=8888

# Spark application UIs — exactly two are published per instance
SPARK_APP1_UI_PORT=4040
SPARK_APP2_UI_PORT=4041

# ── Multi-user / isolation knobs (set per-instance by scripts/provision.sh) ──────
# Left at defaults here for single-instance mode. The provisioner overrides them
# per user so instances never collide.
#
# INSTANCE       — name prefix for containers (default: despark)
# WORKSPACE      — host dir bind-mounted as notebooks/data/apps (default: .)
# NETWORK_NAME   — docker network name (default: despark-spark-net)
# SUBNET         — network subnet (default: 172.28.0.0/24)
# BASE_IMAGE     — base image tag (default: despark-base:3.5.3)
# SPARK_IMAGE    — spark image tag (default: despark-spark:3.5.3)
# JUPYTER_IMAGE  — jupyter image tag (default: despark-jupyter)
