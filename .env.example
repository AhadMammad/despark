# Copy this to .env and adjust for your machine
SPARK_VERSION=3.5.3

# Worker resources — lower these on machines with <8GB RAM
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2

# Master
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=8080

# Worker UIs
SPARK_WORKER1_WEBUI_PORT=8081
SPARK_WORKER2_WEBUI_PORT=8082

# Jupyter
JUPYTER_PORT=8888

# Application UI range (one port per running app)
SPARK_APP_UI_PORT_START=4040
SPARK_APP_UI_PORT_END=4045
